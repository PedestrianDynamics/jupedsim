#! /usr/bin/env bash
export JPSCORE_SOURCE_PATH="@CMAKE_SOURCE_DIR@"
export PYTHONPATH="@CMAKE_SOURCE_DIR@/performancetest:@CMAKE_SOURCE_DIR@/python_modules/jupedsim:@CMAKE_SOURCE_DIR@/python_modules/jupedsim_visualizer:@CMAKE_SOURCE_DIR@/python_modules/jupedsim_examples:@CMAKE_LIBRARY_OUTPUT_DIRECTORY@"

echo "Source path ${JPSCORE_SOURCE_PATH}"
echo "PYTHONPATH=${PYTHONPATH}"

@Python_EXECUTABLE@ -m pytest  ${JPSCORE_SOURCE_PATH}/systemtest ${JPSCORE_SOURCE_PATH}/python_modules/jupedsim/tests ${JPSCORE_SOURCE_PATH}/python_modules/jupedsim_examples/tests --basetemp="$(pwd)/test-results" "$@"
